# Obsidian Wiki 配置
# 请根据需要修改以下设置

# Wiki Vault 位置（必须是绝对路径）
OBSIDIAN_VAULT_PATH=/home/zhangzhongqiang/Work/MyWiki

# 源文档目录（可多个，逗号分隔）
OBSIDIAN_SOURCES_DIR=/home/zhangzhongqiang/Documents

# Claude 历史记录路径（留空则自动发现）
CLAUDE_HISTORY_PATH=

# QMD 配置（用于语义搜索）
# QMD_WIKI_COLLECTION=
# QMD_PAPERS_COLLECTION=
# QMD_TRANSPORT=mcp
# QMD_CLI_SEARCH_MODE=quality

# Token 预算警告阈值（0 表示禁用警告）
WIKI_TOKEN_WARN_THRESHOLD=100000

# 是否启用阶段写入（true 将新页面先写入 _staging/）
WIKI_STAGED_WRITES=false